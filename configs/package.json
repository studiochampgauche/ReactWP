{
  "name": "reactwp-tooling",
  "version": "3.0.0",
  "private": true,
  "description": "ReactWP v3 build tooling",
  "type": "module",
  "scripts": {
    "build": "node ./scripts/project-pipeline.mjs build",
    "build:themes": "node ./scripts/theme-pipeline.mjs build",
    "build:themes:js": "webpack --mode development --config webpack.themes.config.js",
    "build:themes:css": "node ./scripts/build-theme-styles.mjs build",
    "build:plugins": "webpack --mode development --config webpack.plugins.config.js",
    "build:mu-plugins": "webpack --mode development --config webpack.mu-plugins.config.js",
    "watch": "node ./scripts/project-pipeline.mjs watch",
    "watch:themes": "node ./scripts/theme-pipeline.mjs watch",
    "watch:themes:js": "webpack --mode development --config webpack.themes.config.js --watch",
    "watch:themes:css": "node ./scripts/build-theme-styles.mjs watch",
    "watch:plugins": "webpack --mode development --config webpack.plugins.config.js --watch",
    "watch:mu-plugins": "webpack --mode development --config webpack.mu-plugins.config.js --watch",
    "prod": "node ./scripts/project-pipeline.mjs prod",
    "prod:themes": "node ./scripts/theme-pipeline.mjs prod",
    "prod:themes:js": "webpack --mode production --config webpack.themes.config.js",
    "prod:themes:css": "node ./scripts/build-theme-styles.mjs prod",
    "report:themes": "node ./scripts/report-bundle-sizes.mjs",
    "prod:plugins": "webpack --mode production --config webpack.plugins.config.js",
    "prod:mu-plugins": "webpack --mode production --config webpack.mu-plugins.config.js",
    "get:core": "node ./scripts/get-core.mjs"
  },
  "devDependencies": {
    "@babel/core": "8.0.1",
    "@babel/preset-env": "8.0.2",
    "@babel/preset-react": "8.0.1",
    "babel-loader": "10.1.1",
    "copy-webpack-plugin": "14.0.0",
    "css-loader": "7.1.4",
    "gsap": "3.15.0",
    "image-minimizer-webpack-plugin": "5.0.0",
    "imagemin": "9.0.1",
    "imagemin-gifsicle": "7.0.0",
    "imagemin-jpegtran": "8.0.0",
    "imagemin-mozjpeg": "10.0.0",
    "imagemin-optipng": "8.0.0",
    "imagemin-pngquant": "10.0.0",
    "imagemin-svgo": "12.0.0",
    "mini-css-extract-plugin": "2.10.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.1",
    "sass": "1.101.0",
    "sass-loader": "17.0.0",
    "style-loader": "4.0.0",
    "terser-webpack-plugin": "5.6.1",
    "webpack": "5.108.4",
    "webpack-cli": "7.2.1"
  }
}
